# syntax=docker/dockerfile:1
#
# Live-coding image for the Vite/React dashboard. `npm run dev` serves with HMR;
# `docker compose watch` streams src changes in. Node's inspector is exposed for
# debugging the dev server (NODE_OPTIONS=--inspect is set in docker-compose.dev.yml).
#
# Node 22 satisfies Vite 7's engine floor (>= 20.19 / >= 22.12).
FROM node:22-alpine

WORKDIR /app

# Install against the committed lockfile first, in its own layer (cached across
# src edits; only a package.json/lock change re-runs it — the watch rule rebuilds).
COPY package.json package-lock.json ./
RUN npm ci

# App source. compose watch re-syncs src/index.html/vite.config on change.
COPY . .

# Vite dev server + node inspector; published by compose (392xx range).
EXPOSE 39285 39295

CMD ["npm", "run", "dev"]

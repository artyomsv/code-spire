# ---------------------------------------------------------------------------
# Local development environment contract. Copy to .env and fill in.
# .env is gitignored; every key used by docker-compose or the app is listed
# here with a SAFE PLACEHOLDER. Missing values fail fast (no silent defaults
# for credentials).
# ---------------------------------------------------------------------------

# --- Postgres (docker-compose) ---
# Host ports follow the 34xxx project range (34432 echoes conventional 5432).
POSTGRES_PORT=34432
POSTGRES_DB=spire
POSTGRES_USER=spire
POSTGRES_PASSWORD=CHANGE_ME

# --- Redpanda / Kafka (docker-compose) ---
KAFKA_PORT=34092
# Services read the broker from here in dev (default localhost:34092):
# KAFKA_BOOTSTRAP_SERVERS=localhost:34092

# --- Service HTTP ports (quarkus dev; 34xxx range; distinct per service) ---
ORCHESTRATOR_HTTP_PORT=34080
GATEWAY_HTTP_PORT=34081
WORKER_HTTP_PORT=34082

# --- Providers (chosen explicitly; dev defaults to stub) ---
# SPIRE_SCM_PROVIDER=bitbucket-cloud     # stub | bitbucket-cloud
# SPIRE_LLM_PROVIDER=openai-compatible   # stub | openai-compatible

# --- Bitbucket Cloud bot (required when SPIRE_SCM_PROVIDER=bitbucket-cloud) ---
# The ONE bot account. App Password scopes: pullrequest:write, repository:read.
# Names map canonically to spire.scm.bitbucket.* config keys.
# Least privilege per service: the GATEWAY needs only WEBHOOK_SECRET +
# BOT_ACCOUNT_ID; the WORKER needs USERNAME + APP_PASSWORD + BOT_ACCOUNT_ID
# (and never the webhook secret).
# SPIRE_SCM_BITBUCKET_BOT_USERNAME=REPLACE_ME          # worker only
# SPIRE_SCM_BITBUCKET_BOT_APP_PASSWORD=REPLACE_ME      # worker only
# SPIRE_SCM_BITBUCKET_WEBHOOK_SECRET=REPLACE_ME        # gateway only
# SPIRE_SCM_BITBUCKET_BOT_ACCOUNT_ID=REPLACE_ME        # gateway + worker
# SPIRE_SCM_BITBUCKET_BASE_URL=https://api.bitbucket.org/2.0   # override only for testing

# --- LLM (required when SPIRE_LLM_PROVIDER=openai-compatible) ---
# Any OpenAI-compatible endpoint: OpenAI, Azure, Ollama, vLLM, a gateway.
# SPIRE_LLM_BASE_URL=https://api.openai.com/v1
# SPIRE_LLM_API_KEY=REPLACE_ME
# SPIRE_LLM_MODEL=REPLACE_ME

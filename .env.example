# ---------------------------------------------------------------------------
# Local development environment contract. Copy to .env and fill in.
# .env is gitignored; every key the app or docker-compose reads is listed here
# with a SAFE PLACEHOLDER. Credentials have no defaults — missing values fail
# fast. NOTE: never put an inline "# comment" after a value; some parsers fold
# it into the value. Keep annotations on their own lines.
# ---------------------------------------------------------------------------

# --- Postgres (docker-compose) ---
# Host ports follow the 34xxx project range (34432 echoes conventional 5432).
POSTGRES_PORT=34432
POSTGRES_DB=spire
POSTGRES_USER=spire
POSTGRES_PASSWORD=CHANGE_ME

# --- Redpanda / Kafka (docker-compose) ---
KAFKA_PORT=34092
# Services read the broker from here in dev (default localhost:34092):
# KAFKA_BOOTSTRAP_SERVERS=localhost:34092

# --- Service HTTP ports (quarkus dev; 34xxx range; distinct per service) ---
ORCHESTRATOR_HTTP_PORT=34080
GATEWAY_HTTP_PORT=34081
WORKER_HTTP_PORT=34082

# --- Encryption at rest (Tink AES-256-GCM) ---
# The master keyset (base64 Tink keyset) — the ONE bootstrap secret; everything
# else sensitive is encrypted with it. Generate your OWN, never reuse an example.
# Required by the ORCHESTRATOR always, and by the WORKER in active mode (ADR-015:
# the worker decrypts the per-command SCM credential the orchestrator brokers).
# SPIRE_ENCRYPTION_KEYSET=REPLACE_ME

# --- Providers (chosen explicitly; dev defaults to stub when unset) ---
# SPIRE_SCM_PROVIDER: stub | bitbucket-cloud
# SPIRE_LLM_PROVIDER: stub | openai-compatible
# SPIRE_SCM_PROVIDER=bitbucket-cloud
# SPIRE_LLM_PROVIDER=openai-compatible

# --- Review mode (orchestrator) ---
# SPIRE_REVIEW_MODE: active (default) | observe — observe registers PR events
#   but runs NO review (no diff/LLM/comments). The per-provider PR-author
#   allowlist lives in the DB (Settings -> Providers), not here.
# SPIRE_REVIEW_MODE=observe

# --- Bitbucket Cloud (GATEWAY webhook only) ---
# The orchestrator (manual-register + observe), the worker (active-mode
# diff/comment, ADR-015) AND the self-loop guard (drop the bot's own events) all
# use the encrypted provider registry (Settings -> Providers) — including the bot
# account id, which is auto-resolved from the token on save. The GATEWAY holds no
# identity: it only verifies inbound webhook signatures.
#   WEBHOOK_SECRET — HMAC to verify webhook signatures
# SPIRE_SCM_BITBUCKET_WEBHOOK_SECRET=REPLACE_ME

# --- LLM (required when SPIRE_LLM_PROVIDER=openai-compatible) ---
# Any OpenAI-compatible endpoint: OpenAI, Azure, Ollama, vLLM, a gateway.
# SPIRE_LLM_BASE_URL=https://api.openai.com/v1
# SPIRE_LLM_API_KEY=REPLACE_ME
# SPIRE_LLM_MODEL=REPLACE_ME
